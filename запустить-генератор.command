#!/bin/bash
# Запуск генератора лендингов одним кликом

cd "$(dirname "$0")"

# на всякий случай гасим старый сервер, если он уже где-то висит
pkill -f "python3 app.py" 2>/dev/null
sleep 1

echo "Запускаю сервис..."
(python3 app.py > /tmp/landing-generator.log 2>&1 &)

# ждём, пока сервер поднимется, и открываем форму в браузере
sleep 3
open "http://localhost:5050"

echo ""
echo "Готово! Форма открылась в браузере: http://localhost:5050"
echo "Это окно можно закрыть — сервис продолжит работать в фоне."
echo "Чтобы остановить сервис позже, просто перезапусти компьютер или этот же файл (он сам перезапустит сервер)."
